rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAgent() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if request.auth.uid == userId || isAdmin();
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Clients collection
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Summaries collection
    match /summaries/{summaryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (
        isAgent() &&
        resource.data.createdBy == request.auth.uid &&
        exists(/databases/$(database)/documents/editRequests/$(summaryId)) &&
        get(/databases/$(database)/documents/editRequests/$(summaryId)).data.status == 'approved'
      );
      allow delete: if isAdmin();
    }

    // Edit Requests collection
    match /editRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.agentId == request.auth.uid
      );
      allow update: if isAdmin() || (
        isAgent() &&
        resource.data.agentId == request.auth.uid &&
        (request.resource.data.status == 'completed' || request.resource.data.status == 'pending')
      );
      allow delete: if isAdmin() || (
        isAgent() &&
        resource.data.agentId == request.auth.uid
      );
    }

    // Client Edit Requests collection
    match /clientEditRequests/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.agentId == request.auth.uid
      );
      allow update: if isAdmin() || (
        isAgent() &&
        resource.data.agentId == request.auth.uid &&
        (request.resource.data.status == 'completed' || request.resource.data.status == 'pending')
      );
      allow delete: if isAdmin() || (
        isAgent() &&
        resource.data.agentId == request.auth.uid
      );
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Activity Logs collection
    match /activityLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
  }
}
